# ── Local AI (no keys needed) ──────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b-instruct-q4_K_M
EMBED_MODEL=nomic-embed-text
COMFYUI_URL=http://localhost:8188

# ── Python microservices ────────────────────
TTS_SERVICE_URL=http://localhost:8001
STT_SERVICE_URL=http://localhost:8002
PDF_SERVICE_URL=http://localhost:8004
RERANKER_SERVICE_URL=http://localhost:8005

# ── Infrastructure ──────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=edugenie_docs
QDRANT_VECTOR_SIZE=768
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=86400

# ── Free API keys (fill these in) ──────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Backend ─────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_to_a_random_32_char_string

# ── Hardware constraints ─────────────────────
VRAM_EXCLUSIVE_LOCK=true
MAX_CONCURRENT_AI_CALLS=1
